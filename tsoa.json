{
  "entryFile": "src/index.ts",
  "noImplicitAdditionalProperties": "silently-remove-extras",
  "basePath": "/v1",
  "controllerPathGlobs": ["src/controllers/**/*.ts"],
  "spec": {
    "outputDirectory": "src",
    "specVersion": 3,
    "securityDefinitions": {
      "session": {
        "type": "apiKey",
        "name": "toodl_session",
        "in": "cookie"
      }
    }
  },
  "routes": {
    "routesDir": "src",
    "authenticationModule": "src/authentication.ts",
    "iocModule": "src/ioc.ts",
    "esm": true
  }
}
