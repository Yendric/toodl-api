    "jiti": "^2.6.1",
    "prettier": "3.8.2",
    "prisma": "7.7.0",
    "prisma-mock": "^1.1.0",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.4",
    "vitest-mock-extended": "^4.0.0"
  },
  "imports": {
    "#/*": "./src/*"
