{
  "name": "toodl-api",
  "version": "2.0.0",
  "description": "Toodl Api",
  "repository": {
    "type": "git",
    "url": "https://github.com/Yendric/toodl-api"
  },
  "scripts": {
    "build": "pnpm tsoa:gen && tsc",
    "serve": "pnpm dlx prisma migrate deploy && node ./dist/server.js",
    "dev": "pnpm tsoa:gen && DEBUG=true node --watch --import @swc-node/register/esm-register ./src/server.ts",
    "lint": "pnpm tsoa:gen && eslint .",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm tsoa:gen && vitest run --coverage",
    "tsoa:gen": "tsoa spec-and-routes"
  },
  "author": "Yendric Van Roey",
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@colors/colors": "^1.6.0",
    "@google/genai": "^1.49.0",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "7.7.0",
    "@tsoa/runtime": "7.0.0-alpha.0",
    "@types/session-file-store": "^1.2.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dayjs": "^1.11.9",
    "dotenv-expand": "^12.0.3",
    "express": "^5",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.17.3",
    "fractional-indexing": "^3.2.0",
    "google-auth-library": "^9.0.0",
    "helmet": "^8.0.0",
    "inversify": "^8.1.0",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.4",
