generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model List {
  id        Int      @id @default(autoincrement())
  name      String
  color     String   @default("#000000")
  type      ListType @default(REGULAR)
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos     Todo[]

  @@unique([id, userId])
}

enum ListType {
  REGULAR
  SHOPPING
}

model Todo {
  id                  Int       @id @default(autoincrement())
  subject             String
  description         String?
  enableDeadline      Boolean?  @default(false)
  isAllDay            Boolean?
  location            String?
  recurrenceRule      String?
  startTimezone       String?
  endTimezone         String?
  startTime           DateTime?
  endTime             DateTime?
  recurrenceException String?
  position            String    @default("a0")
  done                Boolean   @default(false)
  listId              Int?
  userId              Int
  categoryId          Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  list                List?     @relation(fields: [listId], references: [id], onDelete: Cascade)
  category            Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([id, userId])
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  todos     Todo[]
  storeOrders StoreCategoryOrder[]

  @@unique([id, userId])
}

model Store {
  id        Int      @id @default(autoincrement())
  name      String
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryOrders StoreCategoryOrder[]

  @@unique([id, userId])
}

model StoreCategoryOrder {
  storeId    Int
  categoryId Int
  position   Int
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  @@id([storeId, categoryId])
}

model User {
  id                   Int      @id @default(autoincrement())
  email                String   @unique(map: "sqlite_autoindex_Users_1")
  password             String?
  username             String
  dailyNotification    Boolean  @default(true)
  reminderNotification Boolean  @default(true)
  nowNotification      Boolean  @default(true)
  icalUrls             String[] @default([])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  lists                List[]
  todos                Todo[]
  categories           Category[]
  stores               Store[]
}
